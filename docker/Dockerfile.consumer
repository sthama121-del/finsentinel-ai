# FinSentinel AI - Kafka Consumer Dockerfile
FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y curl && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY . .

RUN useradd --create-home finsentinel && chown -R finsentinel /app
USER finsentinel

CMD ["python", "-m", "pipeline.streaming.kafka_consumer"]
