# FinSentinel AI - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit your actual .env file to git

# ─── App ───────────────────────────────────────────────────────────────────────
APP_NAME=FinSentinel AI
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=local

# ─── LLM Provider (CHANGE THIS TO SWITCH PROVIDERS) ───────────────────────────
# Options: ollama | openai | anthropic | azure_openai
LLM_PROVIDER=ollama
LLM_MODEL=mistral:7b-instruct
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# ─── Ollama (Local - Default, runs on your machine) ───────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── OpenAI (Optional - uncomment to use) ─────────────────────────────────────
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o
# OPENAI_API_KEY=<paste-your-openai-key-here>

# ─── Anthropic (Optional - uncomment to use) ──────────────────────────────────
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_API_KEY=<paste-your-anthropic-key-here>

# ─── Azure OpenAI (Optional - for cloud deployment) ───────────────────────────
# LLM_PROVIDER=azure_openai
# LLM_MODEL=gpt-4o
# AZURE_OPENAI_API_KEY=<paste-your-azure-key-here>
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# ─── Vector Store ──────────────────────────────────────────────────────────────
# Options: chroma | qdrant | azure_cognitive_search
VECTOR_STORE=chroma
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ─── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=finuser
POSTGRES_PASSWORD=<your-postgres-password>
POSTGRES_DB=finsentinel
POSTGRES_URL=postgresql://finuser:<your-postgres-password>@localhost:5432/finsentinel

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Event Streaming ───────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_TRANSACTIONS=fin.transactions.raw
KAFKA_TOPIC_ALERTS=fin.alerts
KAFKA_TOPIC_AUDIT=fin.audit.logs

# ─── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./data

# ─── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=<generate-a-random-32-char-string>
PII_MASKING_ENABLED=true
AUDIT_LOG_ENABLED=true

# ─── Airflow ───────────────────────────────────────────────────────────────────
AIRFLOW_SECRET_KEY=<generate-a-random-32-char-string>
AIRFLOW_ADMIN_PASSWORD=<your-airflow-admin-password>

# ─── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=<your-grafana-admin-password>

# ─── Cache ─────────────────────────────────────────────────────────────────────
LLM_CACHE_ENABLED=true
LLM_CACHE_TTL=3600

# ─── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
OTEL_ENDPOINT=http://localhost:4317
